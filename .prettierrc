{
    "trailingComma": "es5",
    "tabWidth": 4,
    "printWidth": 90,
    "semi": true,
    "singleQuote": false,
    "bracketSpacing": true,
    "plugins": ["prettier-plugin-tailwindcss"],
    "importOrder": [
        "^(react/(.*)$)|^(react$)",
        "<THIRD_PARTY_MODULES>",
        "^types$",
        "^@/env(.*)$",
        "^@/types/(.*)$",
        "^@/config/(.*)$",
        "^@/assets/(.*)$",
        "^@/lib/(.*)$",
        "^@/hooks/(.*)$",
        "^@/components/ui/(.*)$",
        "^@/components/(.*)$",
        "^@/styles/(.*)$",
        "^@/app/(.*)$",
        "^[./]"
    ],
    "tailwindFunctions": ["cn", "clsx", "twMerge"]
}
